{
    "version":  "2.0",
    "envId":  "cloudbase-d3gtnhob5d143914c",
    "framework":  {
                      "name":  "live-location-share-app",
                      "plugins":  {
                                      "client":  {
                                                     "use":  "@cloudbase/framework-plugin-container",
                                                     "inputs":  {
                                                                    "serviceName":  "live-location-backend",
                                                                    "servicePath":  "/",
                                                                    "containerPort":  8787,
                                                                    "uploadType":  "package",
                                                                    "localPath":  "./backend",
                                                                    "dockerfilePath":  "./Dockerfile",
                                                                    "mode":  "low-cost",
                                                                    "cpu":  0.25,
                                                                    "mem":  0.5,
                                                                    "minNum":  0,
                                                                    "maxNum":  2,
                                                                    "envVariables":  {
                                                                                         "HOST":  "0.0.0.0",
                                                                                         "PORT":  "8787",
                                                                                         "STORAGE_DRIVER":  "memory"
                                                                                     }
                                                                }
                                                 }
                                  }
                  }
}
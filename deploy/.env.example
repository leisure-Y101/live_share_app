# Copy this file to deploy/.env on your cloud server and replace passwords.
HOST=0.0.0.0
PORT=8787
STORAGE_DRIVER=mysql

STALE_PARTICIPANT_MS=35000
ROOM_IDLE_MS=21600000
MAX_PARTICIPANTS_PER_ROOM=50
INVITE_CODE_LENGTH=6
AUDIT_LOG_RETENTION_DAYS=30

MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
DB_HOST=mysql
DB_PORT=3306
DB_USER=live_location
DB_PASSWORD=replace-with-a-strong-db-password
DB_NAME=live_location_share
DB_CHARSET=utf8mb4
DB_CONNECTION_LIMIT=10
DB_AUTO_MIGRATE=true

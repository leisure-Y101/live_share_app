.room-screen {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #dbeafe;
}

.room-map {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.menu-anchor {
  position: absolute;
  top: 36rpx;
  left: 24rpx;
  z-index: 7;
}

.menu-toggle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: rgba(15, 23, 42, 0.72);
  backdrop-filter: blur(16rpx);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.2);
}

.menu-toggle-active {
  background: rgba(37, 99, 235, 0.92);
}

.menu-line {
  width: 100%;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.top-summary {
  position: absolute;
  top: 36rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-end;
  z-index: 4;
}

.summary-chip {
  min-width: 168rpx;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(16rpx);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.14);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #64748b;
}

.summary-value {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 700;
}

.floating-actions {
  position: absolute;
  right: 24rpx;
  bottom: 44rpx;
  z-index: 4;
}

.floating-button {
  min-width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0 32rpx;
  border-radius: 999rpx;
  border: none;
  background: rgba(255, 255, 255, 0.92);
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.18);
}

.drawer-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 23, 42, 0.22);
  z-index: 5;
}

.drawer {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 560rpx;
  padding: 44rpx 24rpx 36rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(255, 255, 255, 0.96)),
    #ffffff;
  box-shadow: 24rpx 0 60rpx rgba(15, 23, 42, 0.18);
  transform: translateX(-108%);
  transition: transform 220ms ease;
  z-index: 6;
  display: flex;
  flex-direction: column;
}

.drawer-open {
  transform: translateX(0);
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.drawer-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.drawer-subtitle {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.drawer-close {
  min-width: 108rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  text-align: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.drawer-close-text {
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 600;
}

.drawer-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #f8fafc;
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.14);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.drawer-card-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.invite-card {
  background: linear-gradient(135deg, #eff6ff, #ffffff);
}

.invite-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.invite-code {
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: #0f172a;
}

.drawer-mini-button {
  min-width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border: none;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
}

.drawer-card-tip {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.drawer-action-row {
  display: flex;
  gap: 16rpx;
}

.drawer-action-half {
  flex: 1;
}

.status-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.status-pill {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.status-pill-label {
  font-size: 24rpx;
  color: #64748b;
}

.status-pill-value {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 700;
  text-align: right;
}

.member-card {
  margin-bottom: 18rpx;
}

.drawer-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.drawer-card-meta {
  font-size: 22rpx;
  color: #64748b;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.member-item:first-child {
  padding-top: 6rpx;
}

.member-item:last-child {
  border-bottom: none;
  padding-bottom: 6rpx;
}

.member-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.member-name {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 700;
}

.member-meta {
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.6;
}

.member-state {
  font-size: 22rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.online {
  background: #dcfce7;
  color: #166534;
}

.offline {
  background: #fee2e2;
  color: #b91c1c;
}

.note-card {
  gap: 12rpx;
}

.note-text {
  font-size: 23rpx;
  color: #475569;
  line-height: 1.7;
}

.note-warning {
  font-size: 22rpx;
  color: #b45309;
  line-height: 1.6;
}

.drawer-footer {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.drawer-scroll {
  flex: 1;
  min-height: 0;
}

.footer-button {
  width: 100%;
}

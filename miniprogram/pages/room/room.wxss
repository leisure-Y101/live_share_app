.room-screen {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #dbeafe;
}

.room-map {
  width: 100%;
  height: 100%;
}

.map-gradient {
  position: absolute;
  left: 0;
  right: 0;
  pointer-events: none;
  z-index: 1;
}

.top-gradient {
  top: 0;
  height: 260rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.34), rgba(15, 23, 42, 0));
}

.bottom-gradient {
  bottom: 0;
  height: 360rpx;
  background: linear-gradient(0deg, rgba(15, 23, 42, 0.22), rgba(15, 23, 42, 0));
}

.top-bar {
  position: absolute;
  top: 28rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.room-chip,
.status-card,
.bottom-sheet,
.tool-button {
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 50rpx rgba(15, 23, 42, 0.16);
}

.room-chip {
  min-width: 250rpx;
  padding: 16rpx 22rpx;
  border-radius: 28rpx;
}

.chip-label,
.status-label,
.sheet-kicker,
.panel-label,
.panel-meta,
.privacy-text,
.privacy-warning,
.member-name,
.member-meta,
.member-state,
.sheet-sync,
.chip-value,
.status-value,
.invite-code {
  display: block;
}

.chip-label,
.status-label,
.sheet-kicker,
.panel-meta {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}

.chip-value {
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 5rpx;
}

.top-actions,
.status-strip,
.map-tools,
.sheet-header,
.invite-panel,
.invite-actions,
.section-title-row,
.member-item,
.sheet-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.icon-button,
.mini-button {
  margin: 0;
  padding: 0 22rpx;
  min-width: 112rpx;
  height: 64rpx;
  line-height: 64rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.14);
}

.icon-button.primary,
.mini-button.primary {
  background: #2563eb;
  color: #ffffff;
}

.status-strip {
  position: absolute;
  top: 134rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 3;
}

.status-card {
  flex: 1;
  min-width: 0;
  padding: 16rpx 14rpx;
  border-radius: 24rpx;
}

.status-value {
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-tools {
  position: absolute;
  right: 24rpx;
  bottom: 190rpx;
  z-index: 3;
  flex-direction: column;
  align-items: stretch;
}

.tool-button {
  margin: 0;
  min-width: 172rpx;
  height: 74rpx;
  line-height: 74rpx;
  border: none;
  border-radius: 999rpx;
  color: #0f172a;
  font-size: 25rpx;
  font-weight: 900;
}

.panel-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 4;
  background: rgba(15, 23, 42, 0.18);
}

.bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  height: 132rpx;
  padding: 16rpx 24rpx 34rpx;
  border-radius: 38rpx 38rpx 0 0;
  box-sizing: border-box;
  transition: height 220ms ease;
}

.bottom-sheet-open {
  height: 980rpx;
}

.sheet-handle {
  width: 88rpx;
  height: 10rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: #cbd5e1;
}

.sheet-header {
  justify-content: space-between;
}

.sheet-title {
  display: block;
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-sync {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 700;
}

.sheet-scroll {
  height: 820rpx;
  margin-top: 18rpx;
}

.invite-panel,
.member-section,
.privacy-panel {
  padding: 22rpx;
  border-radius: 28rpx;
  background: #f8fafc;
  margin-bottom: 18rpx;
}

.invite-panel {
  justify-content: space-between;
  background: linear-gradient(135deg, #eff6ff, #ffffff);
}

.invite-code {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 7rpx;
}

.panel-label {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 900;
}

.section-title-row {
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.empty-members {
  padding: 24rpx 0 4rpx;
  color: #64748b;
  font-size: 25rpx;
  text-align: center;
}

.member-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 22rpx;
  text-align: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.avatar-online {
  background: linear-gradient(135deg, #2563eb, #06b6d4);
}

.avatar-offline {
  background: #94a3b8;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.member-state {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.online {
  background: #dcfce7;
  color: #166534;
}

.offline {
  background: #fee2e2;
  color: #b91c1c;
}

.privacy-text,
.privacy-warning {
  margin-top: 12rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.65;
}

.privacy-warning {
  color: #b45309;
}

.sheet-actions {
  flex-direction: column;
  align-items: stretch;
  padding-bottom: 30rpx;
}

.sheet-button {
  width: 100%;
  margin: 0;
}

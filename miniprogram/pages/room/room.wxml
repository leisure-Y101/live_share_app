<view class="room-screen">
  <map id="liveMap" class="room-map" latitude="{{mapCenter.latitude}}" longitude="{{mapCenter.longitude}}" scale="{{mapScale}}" markers="{{markers}}" show-location />

  <view class="map-gradient top-gradient"></view>
  <view class="map-gradient bottom-gradient"></view>

  <view class="top-bar">
    <view class="room-chip">
      <text class="chip-label">邀请码</text>
      <text class="chip-value">{{inviteCode}}</text>
    </view>
    <view class="top-actions">
      <button class="icon-button" bindtap="copyInviteCode">复制</button>
      <button class="icon-button primary" open-type="share">分享</button>
    </view>
  </view>

  <view class="status-strip">
    <view class="status-card">
      <text class="status-label">在线</text>
      <text class="status-value">{{participants.length}} 人</text>
    </view>
    <view class="status-card">
      <text class="status-label">连接</text>
      <text class="status-value">{{connectionStatus}}</text>
    </view>
    <view class="status-card">
      <text class="status-label">定位</text>
      <text class="status-value">{{locationStatus}}</text>
    </view>
  </view>

  <view class="map-tools">
    <button class="tool-button" bindtap="centerOnSelf">定位到我</button>
    <button class="tool-button" bindtap="togglePanel">{{panelOpen ? '收起' : '成员'}}</button>
  </view>

  <view wx:if="{{panelOpen}}" class="panel-mask" bindtap="closePanel"></view>

  <view class="bottom-sheet {{panelOpen ? 'bottom-sheet-open' : ''}}" catchtap="noop">
    <view class="sheet-handle" bindtap="togglePanel"></view>
    <view class="sheet-header">
      <view>
        <text class="sheet-kicker">共享地图</text>
        <text class="sheet-title">房间控制台</text>
      </view>
      <text class="sheet-sync">同步 {{lastSyncText}}</text>
    </view>

    <scroll-view class="sheet-scroll" scroll-y>
      <view class="invite-panel">
        <view>
          <text class="panel-label">邀请码</text>
          <text class="invite-code">{{inviteCode}}</text>
        </view>
        <view class="invite-actions">
          <button class="mini-button" bindtap="copyInviteCode">复制</button>
          <button class="mini-button primary" open-type="share">分享</button>
        </view>
      </view>

      <view class="member-section">
        <view class="section-title-row">
          <text class="panel-label">成员位置</text>
          <text class="panel-meta">{{participants.length}} 人</text>
        </view>
        <view class="empty-members" wx:if="{{participants.length === 0}}">等待成员加入</view>
        <view class="member-item" wx:for="{{participants}}" wx:key="participantId">
          <view class="member-avatar {{item.online ? 'avatar-online' : 'avatar-offline'}}">{{item.avatarText}}</view>
          <view class="member-main">
            <text class="member-name">{{item.displayName}}{{item.isSelf ? '（我）' : ''}}</text>
            <text class="member-meta">{{item.locationText}}</text>
          </view>
          <text class="member-state {{item.online ? 'online' : 'offline'}}">{{item.stateText}}</text>
        </view>
      </view>

      <view class="privacy-panel">
        <text class="panel-label">共享说明</text>
        <text class="privacy-text">仅当前房间成员可见，只共享当前位置，不保存历史轨迹。</text>
        <text class="privacy-text">{{locationRetentionText}}</text>
        <text class="privacy-text">{{withdrawLocationPathText}}</text>
        <text class="privacy-text">{{thirdPartyServiceText}}</text>
        <text class="privacy-text">联系邮箱：{{privacyContactEmail}}</text>
        <text wx:if="{{needsRealPrivacyEmail}}" class="privacy-warning">发布前请把联系邮箱替换成真实邮箱。</text>
      </view>

      <view class="sheet-actions">
        <button class="secondary-button sheet-button" bindtap="openLocationSettings">定位权限设置</button>
        <button class="secondary-button sheet-button" bindtap="copyPrivacyEmail">复制联系邮箱</button>
        <button class="danger-button sheet-button" bindtap="confirmLeave">停止共享并删除</button>
      </view>
    </scroll-view>
  </view>
</view>
